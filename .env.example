APP_NAME="Consulting OS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Base de données (Docker) ─────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=consulting_os
DB_USERNAME=laravel
DB_PASSWORD=laravel_password

# ─── Session & Cache ──────────────────────────────────────────────────────────
BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ─── Mail (à configurer plus tard) ───────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@consulting-os.local"
MAIL_FROM_NAME="${APP_NAME}"

# ─── API Intelligence Artificielle ───────────────────────────────────────────
# Utilise l'API Claude d'Anthropic pour l'analyse et la generation de comptes rendus
# Obtenir une cle : https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-VOTRE_CLE_API_ICI

# Optionnel : OpenAI en fallback
OPENAI_API_KEY=
